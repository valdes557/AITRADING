PORT=5000
MONGODB_URI=mongodb://localhost:27017/ai-trading-signals
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=30d

# Signal Engine
SIGNAL_ENGINE_URL=http://localhost:8000

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# WhatsApp Notifications (choose one provider)
WHATSAPP_PROVIDER=callmebot
# Option 1: CallMeBot (free - user must authorize first)
CALLMEBOT_API_KEY=your_callmebot_api_key
# Option 2: Twilio
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Option 3: WhatsApp Business API
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=

# Market APIs
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret

# Crypto Payments
USDT_TRC20_ADDRESS=your_trc20_wallet_address
BINANCE_PAY_API_KEY=your_binance_pay_key

# Frontend URL
FRONTEND_URL=http://localhost:3000

NODE_ENV=development
